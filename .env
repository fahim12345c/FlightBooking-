# ============================================================================
# Flight Booking API - Environment Configuration
# ============================================================================

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Application environment (development, staging, production)
ENVIRONMENT=development

# Enable debug mode (set to false in production)
DEBUG=true

# API Title and Version
API_TITLE=Flight Booking API
API_VERSION=0.1.0

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database URL - Uncomment one based on your preference
# SQLite (local development)
DATABASE_URL=postgresql://postgres:fahim%4017315@db:5432/postgres

# PostgreSQL (production recommended)
# DATABASE_URL=postgresql://flightadmin:flightpass@localhost:5432/flightbooking

# PostgreSQL Environment Variables (for Docker/compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=fahim@17315
POSTGRES_DB=postgres
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432

# Database pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=3600

# ============================================================================
# SECURITY & JWT CONFIGURATION
# ============================================================================

# Secret key for JWT token signing (CHANGE THIS IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=fahim@17315

# JWT Algorithm (HS256, RS256, etc.)
ALGORITHM=HS256

# Access token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration (in days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# EMAIL & SMTP CONFIGURATION
# ============================================================================

# Email provider (gmail, outlook, sendgrid, custom)
EMAIL_PROVIDER=gmail

# SMTP Server configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_TIMEOUT=10

# Sender email credentials
SENDER_EMAIL=fahimalislam1919@gmail.com
SENDER_PASSWORD=mjfx flcj qrwr rsdp

# Email display name
SENDER_NAME=Flight Booking Team

# Alternative: SendGrid API Key (uncomment if using SendGrid)
# SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file location
LOG_FILE=logs/flight_booking.log

# Enable file logging
LOG_TO_FILE=true

# Enable console logging
LOG_TO_CONSOLE=true

